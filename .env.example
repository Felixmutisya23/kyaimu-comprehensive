# ═══════════════════════════════════════════════════════════════
#  EduManage Pro — Environment Variables Template
#  Copy this file to .env for local development.
#  NEVER commit .env to git — it is in .gitignore.
#
#  In Netlify: Site Settings → Environment Variables → Add variable
# ═══════════════════════════════════════════════════════════════

# ── Supabase (required) ─────────────────────────────────────────
# Get these from: Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Security (required) ─────────────────────────────────────────
# A strong random string — protects Netlify functions from external abuse
# Generate one: openssl rand -hex 32
APP_SECRET=replace-with-32-char-random-string

# The URL of your deployed Netlify site (restricts CORS to your domain only)
APP_ORIGIN=https://your-site-name.netlify.app

# ── Developer token generator (required for token system) ───────
# Your personal password to access the token generator
# Set this to something strong — it never appears in frontend code
DEVELOPER_SECRET=your-strong-developer-password-here

# ── InstaSend — M-Pesa payments (required for billing) ─────────
# Get from: https://app.instasend.io → Settings → API Keys
INSTASEND_SECRET_KEY=your-instasend-secret-key

# ── Africa's Talking — SMS (required for SMS feature) ──────────
# Get from: https://account.africastalking.com → Settings → API Key
AT_API_KEY=your-africas-talking-api-key
AT_USERNAME=your-at-username
AT_SENDER_ID=SCHOOL

# ── Africa's Talking — WhatsApp (required for WhatsApp feature) ─
AT_WA_API_KEY=your-at-whatsapp-api-key
AT_WA_PHONE_ID=your-whatsapp-phone-id
